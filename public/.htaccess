# After deploy, browsers must re-fetch index.html so they load the new hashed JS/CSS.
# Otherwise you can see a mix: new HTML briefly, then an old cached bundle (wrong layout).
<IfModule mod_headers.c>
  <Files "index.html">
    Header set Cache-Control "max-age=0, must-revalidate, no-cache"
  </Files>
  <FilesMatch "\.(js|mjs|css|woff2?|ttf|eot|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_negotiation.c>
  Options -MultiViews
</IfModule>
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>